{% block extraScripts %}
<script type="module">
/* pricing integrations (P3, Session G) — RevenueHero pre-wired per Jeff. The pricing bundle
   ships NO form/scheduler; Jeff will add per-plan "Talk to sales" buttons in a future session.
   This loads + instantiates RH (routerId 4693, via head.njk pageJS=="pricing" gate) and attaches
   the scheduler + MEETING_BOOKED→Customer.io attribution to any [data-rh-schedule] element, so
   the future buttons work by adding that attribute. Existing "/book-a-demo" CTAs are untouched. */
import { identifyUser, trackEvent } from '/assets/js/components/customerio.js';
const ROUTER_ID = '4693';
if (typeof RevenueHero !== 'undefined') {
  const hero = new RevenueHero({ routerId: ROUTER_ID });
  const targets = document.querySelectorAll('[data-rh-schedule]');
  if (targets.length) hero.schedule('[data-rh-schedule]');
  window.addEventListener('message', (ev) => {
    if (ev.data && ev.data.type === 'MEETING_BOOKED') {
      const email = ev.data.email || ev.data.inviteeEmail;
      if (email) {
        identifyUser({ email, formName: 'pricing', attributes: { meeting_booked: true, meeting_booked_at: new Date().toISOString(), demo_requested: true }, trackEvent: false });
        trackEvent('meeting_booked', { form_name: 'pricing' });
      }
    }
  });
}
</script>
