{% block extraScripts %}
<script type="module">
/* book-a-demo integrations (P3, Session E) — RevenueHero instant scheduler (Jeff's call) +
   Customer.io identify + n8n webhook, per INTEGRATIONS_PARITY §3.3/§4. Reuses the proven 2.0
   component modules. Fires only on a valid submit (mirrors the designer field-validation). */
import { identifyUser, trackEvent } from '/assets/js/components/customerio.js';
import { getUtmData, flattenUtmForPayload } from '/assets/js/components/utm.js';
import { WEBHOOK_URL } from '/assets/js/config/webhooks.js';

const ROUTER_ID = '4693';
const form = document.querySelector('form[data-form-name="book_a_demo"]');
if (form) {
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const val = (n) => (form.querySelector('[name="'+n+'"]') || {}).value || '';
  const interest = () => { const r = form.querySelector('input[name="interest"]:checked'); return r ? r.value : ''; };
  const isValid = () => emailRe.test(val('email').trim()) && val('name').trim() && val('company').trim() && interest();

  let captured = null;
  async function sendToWebhook(d) {
    try {
      const utm = flattenUtmForPayload(getUtmData());
      const res = await fetch(WEBHOOK_URL, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...d, source: 'book_a_demo', page_url: window.location.href, submitted_at: new Date().toISOString(), ...utm })
      });
      if (!res.ok) console.error('Webhook response not OK:', res.status);
    } catch (e) { console.error('Error sending to webhook:', e); }
  }

  // Capture-phase: fire CIO + webhook before RevenueHero opens the scheduler (only when valid).
  form.addEventListener('submit', () => {
    if (!isValid()) return;
    captured = { name: val('name').trim(), email: val('email').trim(), company: val('company').trim(), role: val('role').trim(), interest: interest() };
    identifyUser({
      email: captured.email, formName: 'book_a_demo',
      attributes: { name: captured.name, company: captured.company, job_title: captured.role, product_interest: captured.interest, demo_requested: true, meeting_booked: false }
    });
    sendToWebhook(captured);
  }, { capture: true });

  if (typeof RevenueHero !== 'undefined') {
    const hero = new RevenueHero({ routerId: ROUTER_ID });
    hero.schedule('form[data-form-name="book_a_demo"]');
    window.addEventListener('message', (ev) => {
      if (ev.data && ev.data.type === 'MEETING_BOOKED' && captured?.email) {
        identifyUser({ email: captured.email, formName: 'book_a_demo', attributes: { meeting_booked: true, meeting_booked_at: new Date().toISOString() }, trackEvent: false });
        trackEvent('meeting_booked', { form_name: 'book_a_demo', company: captured.company });
      }
    });
  } else {
    // Fallback if RevenueHero fails to load: reveal the designer's own success state.
    form.addEventListener('submit', () => { if (isValid()) form.classList.add('is-sent'); });
  }
}
</script>
