        <pre class="dxa__pre"><code><span class="c-c"># Create a booking via the REST API</span>
curl -X POST https://api.slashexperts.com/v1/bookings \
  -H <span class="c-s">"Authorization: Bearer $SE_TOKEN"</span> \
  -H <span class="c-s">"Content-Type: application/json"</span> \
  -d '{
    <span class="c-k">"expert_id"</span>: <span class="c-s">"exp_8Kd2"</span>,
    <span class="c-k">"prospect_email"</span>: <span class="c-s">"buyer@acme.com"</span>,
    <span class="c-k">"source"</span>: <span class="c-s">"website_widget"</span>
  }'

<span class="c-c"># → 201 Created</span>
<span class="c-p">{</span> <span class="c-k">"id"</span>: <span class="c-s">"bk_19Xa"</span>, <span class="c-k">"status"</span>: <span class="c-s">"confirmed"</span> <span class="c-p">}</span></code></pre>
