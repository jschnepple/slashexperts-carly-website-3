{% block extraScripts %}
<script type="module">
/* report-2026 integrations (P3, Session K3) — gated report request (#rpForm / #rpSubmit).
   form_name `download_report_2026` per INTEGRATIONS_PARITY §2; n8n + UTM per §3.1/§3.4.
   NOTE: this design DELIVERS BY EMAIL ("Check your inbox!"), not by browser download — so no
   PDF is fetched here and no `pdf_downloaded` event fires (2.0's variant downloaded instead).
   Capture-phase listener runs before the designer's own success handler; its UX is untouched. */
import { identifyUser } from '/assets/js/components/customerio.js';
import { getUtmData, flattenUtmForPayload } from '/assets/js/components/utm.js';
import { WEBHOOK_URL } from '/assets/js/config/webhooks.js';

const btn = document.getElementById('rpSubmit');
if (btn) {
  const emailRe = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
  const v = (id) => ((document.getElementById(id) || {}).value || '').trim();

  async function sendToWebhook(d) {
    try {
      const res = await fetch(WEBHOOK_URL, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...d,
          timestamp: new Date().toISOString(),
          page: window.location.pathname,
          referrer: document.referrer || null,
          leadSource: '2026 GTM Report',
          ...flattenUtmForPayload(getUtmData())
        })
      });
      if (!res.ok) console.error('Webhook response not OK:', res.status);
    } catch (e) { console.error('Error sending to webhook:', e); }
  }

  btn.addEventListener('click', () => {
    const email = v('rpEmail');
    if (!emailRe.test(email)) return;                     // mirrors the designer's own check
    const d = { firstName: v('rpFirst'), lastName: v('rpLast'), email, company: v('rpCompany'), jobTitle: v('rpTitle') };
    identifyUser({
      email, formName: 'download_report_2026',
      attributes: {
        first_name: d.firstName || null, last_name: d.lastName || null,
        company: d.company || null, job_title: d.jobTitle || null,
        lead_source: '2026 GTM Report', report_type: '2026 GTM Report', report_delivery: 'email'
      }
    });
    sendToWebhook(d);
  }, { capture: true });
}
</script>
