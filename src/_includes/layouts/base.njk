<!DOCTYPE html>
<html lang="en">
<head>
    {% include "partials/head.njk" %}
    {% block extraHead %}{% endblock %}
</head>
<body>
    {# GTM noscript fallback - must be immediately after <body> #}
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W5ZHWLL6"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    {% include "components/nav.njk" %}

    <main>
        {% if lastUpdated %}
        <div class="last-updated-bar">
            <div class="last-updated-inner">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Last updated: <time datetime="{{ lastUpdated }}">{{ lastUpdated | date('MMMM d, Y') }}</time>
            </div>
        </div>
        {% endif %}
        {% block content %}{% endblock %}
    </main>

    {% include "components/footer.njk" %}
    {% include "partials/scripts.njk" %}
    {% block extraScripts %}{% endblock %}
</body>
</html>
