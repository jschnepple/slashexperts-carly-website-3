{% extends "layouts/base.njk" %}

{# Get author data from authors.json #}
{% set authorData = null %}
{% for a in authors %}
  {% if a.slug == author %}
    {% set authorData = a %}
  {% endif %}
{% endfor %}

{% block extraHead %}
<!-- Article-specific Open Graph Tags (base OG/Twitter tags are in head.njk) -->
<meta property="article:published_time" content="{{ date | date('Y-m-d') }}">
{% if authorData %}
<meta property="article:author" content="{{ authorData.name }}">
{% endif %}
{% if category %}
<meta property="article:section" content="{{ category }}">
{% endif %}
{% for tag in tags %}{% if tag != 'posts' %}
<meta property="article:tag" content="{{ tag }}">
{% endif %}{% endfor %}

<!-- JSON-LD Structured Data -->
{% include "partials/blog-schema.njk" %}
{% endblock %}

{% block content %}
<article class="blog-post" itemscope itemtype="https://schema.org/BlogPosting">
    <!-- Post Header -->
    <header class="post-header">
        <div class="post-header-container">
            <div class="post-meta-top">
                {% if category %}
                <a href="/blog/?category={{ category | urlencode }}" class="post-category-badge">{{ category }}</a>
                {% endif %}
                <time datetime="{{ date | date('Y-m-d') }}" class="post-date" itemprop="datePublished">
                    {{ date | date('MMMM d, Y') }}
                </time>
            </div>

            <h1 class="post-title" itemprop="headline">{{ title }}</h1>

            {% if description %}
            <p class="post-excerpt" itemprop="description">{{ description }}</p>
            {% endif %}

            {% if authorData %}
            <div class="post-author-info" itemprop="author" itemscope itemtype="https://schema.org/Person">
                <div class="author-avatar-large">{{ authorData.initials }}</div>
                <div class="author-details">
                    <span class="author-name" itemprop="name">{{ authorData.name }}</span>
                    <span class="author-title">{{ authorData.title }}</span>
                </div>
                <div class="post-read-time">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span>{{ readTime | default(5) }} min read</span>
                </div>
            </div>
            {% endif %}
        </div>

        {% if featuredImage %}
        <figure class="post-featured-image">
            <picture>
                <source srcset="{{ featuredImage }}" type="image/webp">
                <img src="{{ featuredImage | replace('.webp', '.jpg') }}"
                     alt="{{ featuredImageAlt | default(title) }}"
                     itemprop="image"
                     width="1200"
                     height="630"
                     loading="eager">
            </picture>
        </figure>
        {% endif %}
    </header>

    <!-- Post Content -->
    <div class="post-content" itemprop="articleBody">
        {{ content | safe }}
    </div>

    <!-- Post Footer -->
    <footer class="post-footer">
        <!-- Tags -->
        {% if tags and tags.length > 1 %}
        <div class="post-tags">
            <span class="tags-label">Tags:</span>
            <div class="tags-list">
                {% for tag in tags %}
                {% if tag != 'posts' %}
                <a href="/blog/?tag={{ tag | urlencode }}" class="tag-pill">{{ tag | replace('-', ' ') | title }}</a>
                {% endif %}
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Author Bio -->
        {% if authorData %}
        <div class="author-bio-card">
            <div class="author-avatar-large">{{ authorData.initials }}</div>
            <div class="author-bio-content">
                <h4>About {{ authorData.name }}</h4>
                <p>{{ authorData.bio }}</p>
            </div>
        </div>
        {% endif %}

        <!-- Share Links -->
        <div class="post-share">
            <span class="share-label">Share this article:</span>
            <div class="share-buttons">
                <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url=https://slashexperts.com{{ page.url | urlencode }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="share-btn twitter"
                   aria-label="Share on Twitter">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                </a>
                <a href="https://www.linkedin.com/shareArticle?mini=true&url=https://slashexperts.com{{ page.url | urlencode }}&title={{ title | urlencode }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="share-btn linkedin"
                   aria-label="Share on LinkedIn">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                </a>
                <button class="share-btn copy-link"
                        onclick="navigator.clipboard.writeText('https://slashexperts.com{{ page.url }}').then(() => this.classList.add('copied'))"
                        aria-label="Copy link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Related Posts -->
        <div class="related-posts">
            <h3>Related Articles</h3>
            <div class="related-grid">
                {% set relatedPosts = collections.posts | rejectattr("url", "equalto", page.url) %}
                {% set categoryPosts = [] %}
                {% for post in relatedPosts %}
                    {% if post.data.category == category and categoryPosts | length < 3 %}
                        {% set categoryPosts = (categoryPosts.push(post), categoryPosts) %}
                    {% endif %}
                {% endfor %}

                {% if categoryPosts | length < 3 %}
                    {% for post in relatedPosts %}
                        {% if categoryPosts | length < 3 and post.data.category != category %}
                            {% set categoryPosts = (categoryPosts.push(post), categoryPosts) %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                {% for post in categoryPosts %}
                <a href="{{ post.url }}" class="related-card">
                    {% if post.data.featuredImage %}
                    <div class="related-image">
                        <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" loading="lazy">
                    </div>
                    {% endif %}
                    <div class="related-content">
                        <span class="related-category">{{ post.data.category }}</span>
                        <h4>{{ post.data.title }}</h4>
                        <span class="related-read-time">{{ post.data.readTime | default(5) }} min read</span>
                    </div>
                </a>
                {% endfor %}
            </div>
        </div>
    </footer>
</article>

<!-- Newsletter CTA -->
<section class="post-newsletter">
    <div class="newsletter-inner">
        <h3>Get the <em>Buyer Trust Brief</em> weekly</h3>
        <p>Research-backed insights on peer influence, buyer psychology, and sales acceleration delivered every Tuesday.</p>
        <form class="newsletter-form-inline">
            <input type="email" placeholder="Enter your work email" required>
            <button type="submit" class="btn btn-primary has-glow has-glow-full">Subscribe</button>
        </form>
    </div>
</section>
{% endblock %}
