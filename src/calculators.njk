{% block extraScripts %}
<script type="module">
/* calculators integrations (P3, Session K3; pipeline gate added per Jeff 2026-07-21).
   TWO capture steps on this page, each on the designer's own submit button (capture-phase, so it
   fires before the reveal handler; designer validation/UX untouched):
     • ROI card lead gate      (#roiGate / #gSubmit) → form_name `roi_calculator`
     • Invisible Pipeline gate  (#plGate / #plSubmit) → form_name `pipeline_calculator`  ← NEW (Jeff: gate the quiz)
   Both: Customer.io identify + n8n POST + UTM spread (INTEGRATIONS_PARITY §2 / §3.1 / §3.4).
   `quiz_completed` fires once the visitor has identified via EITHER gate and all 6 answers are in. */
import { identifyUser, trackEvent } from '/assets/js/components/customerio.js';
import { getUtmData, flattenUtmForPayload } from '/assets/js/components/utm.js';
import { WEBHOOK_URL } from '/assets/js/config/webhooks.js';

const emailRe = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
const v = (id) => ((document.getElementById(id) || {}).value || '').trim();
let identified = null;

async function sendToWebhook(d, leadSource) {
  try {
    const res = await fetch(WEBHOOK_URL, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ...d,
        timestamp: new Date().toISOString(),
        page: window.location.pathname,
        referrer: document.referrer || null,
        leadSource,
        ...flattenUtmForPayload(getUtmData())
      })
    });
    if (!res.ok) console.error('Webhook response not OK:', res.status);
  } catch (e) { console.error('Error sending to webhook:', e); }
}

/* ROI card → roi_calculator */
const roiBtn = document.getElementById('gSubmit');
if (roiBtn) {
  roiBtn.addEventListener('click', () => {
    const email = v('gEmail');
    if (!emailRe.test(email)) return;                     // mirrors the designer's own gate check
    const d = { firstName: v('gFirst'), lastName: v('gLast'), email, company: v('gCompany'), role: v('gRole') };
    identified = email;
    identifyUser({
      email, formName: 'roi_calculator',
      attributes: {
        first_name: d.firstName || null, last_name: d.lastName || null,
        company: d.company || null, job_title: d.role || null,
        lead_source: '2026 GTM Report - ROI Calculator'
      }
    });
    sendToWebhook(d, '2026 GTM Report - ROI Calculator');
  }, { capture: true });
}

/* Invisible Pipeline gate → pipeline_calculator (registered form_name) */
const plBtn = document.getElementById('plSubmit');
if (plBtn) {
  plBtn.addEventListener('click', () => {
    const email = v('plEmail');
    if (!emailRe.test(email)) return;                     // mirrors the gate's own email check
    const score = (document.getElementById('scoreNum') || {}).textContent || '';
    const d = { firstName: v('plFirst'), lastName: v('plLast'), email, company: v('plCompany'), role: v('plRole') };
    identified = email;
    identifyUser({
      email, formName: 'pipeline_calculator',
      attributes: {
        first_name: d.firstName || null, last_name: d.lastName || null,
        company: d.company || null, job_title: d.role || null,
        lead_source: '2026 GTM Report - Invisible Pipeline Score',
        pipeline_score: score || null
      }
    });
    sendToWebhook({ ...d, pipelineScore: score, quizType: 'Invisible Pipeline Score' }, '2026 GTM Report - Invisible Pipeline Score');
  }, { capture: true });
}

/* quiz_completed — once identified via either gate and all 6 answers are in */
let quizSent = false;
document.addEventListener('click', (e) => {
  if (quizSent || !identified || !e.target.closest || !e.target.closest('.cx-opt')) return;
  const answered = document.querySelectorAll('.cx-q .cx-opt[aria-pressed="true"]').length;
  const total = document.querySelectorAll('.cx-q').length;
  if (total && answered >= total) {
    quizSent = true;
    const score = (document.getElementById('scoreNum') || {}).textContent || '';
    trackEvent('quiz_completed', { form_name: 'pipeline_calculator', quiz_type: 'Invisible Pipeline Score', pipeline_score: score });
  }
});
</script>
{% endblock %}
