---
permalink: /contact/
title: Contact Us | SlashExperts
description: Get in touch with SlashExperts. Talk to sales, get support, or explore partnership opportunities. We typically respond within 2 hours.
pageCSS: contact
pageJS: contact
lightNav: true
---

{% extends "layouts/base.njk" %}

{% block content %}
<!-- Hero Section -->
<div class="hero-wrapper">
    <div class="background-gradient-wrapper">
        <div class="background-gradient"></div>
        <div class="background-gradient-secondary"></div>
        <div class="background-gradient-tertiary"></div>
        <div class="background-gradient-orange"></div>
        <div class="background-lines"></div>
    </div>

    <section class="contact-hero">
        <div class="hero-content">
            <div class="hero-badge">
                <div class="hero-badge-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                </div>
                Typically respond within 2 hours
            </div>
            <h1>Let's Start a <span class="serif-italic">Conversation</span></h1>
            <p class="hero-subtitle">Have questions about how SlashExperts can transform your sales process? Our team is here to help you unlock the power of peer-to-peer connections.</p>
        </div>
    </section>
</div>

<!-- Contact Options -->
<div class="contact-options-wrapper">
    <div class="contact-options">
        <a href="#contact-form" class="contact-option">
            <div class="response-badge">Usually < 2hrs</div>
            <div class="option-icon sales">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
            </div>
            <h3>Talk to Sales</h3>
            <p>Discover how leading B2B companies are accelerating deals by connecting prospects with their happiest customers.</p>
            <span class="option-cta">
                Schedule a call
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                </svg>
            </span>
        </a>

        <a href="#contact-form" class="contact-option">
            <div class="response-badge">24/7 Available</div>
            <div class="option-icon support">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <h3>Customer Support</h3>
            <p>Already using SlashExperts? Get help with your account, integrations, or any technical questions from our expert team.</p>
            <span class="option-cta">
                Get support
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                </svg>
            </span>
        </a>

        <a href="#contact-form" class="contact-option">
            <div class="option-icon partners">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <h3>Partnerships</h3>
            <p>Interested in integrating with SlashExperts or exploring partnership opportunities? Let's build something great together.</p>
            <span class="option-cta">
                Partner with us
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                </svg>
            </span>
        </a>
    </div>
</div>

<!-- Main Contact Section -->
<div class="main-contact-wrapper">
    <section class="main-contact" id="contact-form">
        <div class="contact-info">
            <h2>We'd Love to <span class="serif-italic">Hear</span> From You</h2>
            <p>Whether you're ready to transform how your prospects discover trust, or just exploring what's possible—we're here to help.</p>

            <div class="contact-details">
                <div class="contact-detail-card">
                    <div class="detail-icon email">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <div class="detail-content">
                        <h4>Email Us</h4>
                        <p><a href="mailto:hello@slashexperts.com">hello@slashexperts.com</a></p>
                    </div>
                </div>

                <div class="contact-detail-card">
                    <div class="detail-icon location">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div class="detail-content">
                        <h4>Headquarters</h4>
                        <p>San Francisco, CA</p>
                    </div>
                </div>
            </div>

            <div class="social-section">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="https://linkedin.com/company/slashexperts" class="social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>
                    <a href="https://x.com/slashexperts" class="social-link" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </a>
                    <a href="https://www.youtube.com/@SlashExperts" class="social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24">
                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="contact-form-wrapper">
            <div class="form-card">
                <div class="form-header">
                    <h3>Send Us a Message</h3>
                    <p>Fill out the form below and we'll get back to you promptly.</p>
                </div>

                <form class="contact-form">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="firstName">First Name</label>
                            <input type="text" id="firstName" name="firstName" placeholder="Jane" required>
                        </div>
                        <div class="form-group">
                            <label for="lastName">Last Name</label>
                            <input type="text" id="lastName" name="lastName" placeholder="Smith" required>
                        </div>
                        <div class="form-group">
                            <label for="email">Work Email</label>
                            <input type="email" id="email" name="email" placeholder="jane@company.com" required>
                        </div>
                        <div class="form-group">
                            <label for="company">Company</label>
                            <input type="text" id="company" name="company" placeholder="Acme Inc.">
                        </div>
                        <div class="form-group full-width">
                            <label for="inquiry">What can we help you with?</label>
                            <select id="inquiry" name="inquiry">
                                <option value="">Select an option...</option>
                                <option value="demo">Book a Demo</option>
                                <option value="pricing">Pricing Information</option>
                                <option value="support">Technical Support</option>
                                <option value="partnership">Partnership Opportunities</option>
                                <option value="press">Press & Media</option>
                                <option value="other">General Inquiry</option>
                            </select>
                        </div>
                        <div class="form-group full-width">
                            <label for="message">Your Message</label>
                            <textarea id="message" name="message" placeholder="Tell us a bit about your goals and how we can help..."></textarea>
                        </div>
                    </div>

                    <div class="form-submit">
                        <button type="submit" class="btn-submit has-glow has-glow-full">
                            Send Message
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="22" y1="2" x2="11" y2="13"/>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </button>
                    </div>

                    <p class="form-note">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        Your information is protected and will never be shared.
                    </p>
                </form>
            </div>
        </div>
    </section>
</div>

<!-- Trust Section -->
<section class="trust-section">
    <div class="trust-content">
        <p class="trust-label">Trusted by Industry Leaders</p>
        <h2 class="trust-title">Join Companies Already Winning with Peer Connections</h2>
        <div class="trust-stats">
            <div class="trust-stat">
                <div class="trust-stat-value">500+</div>
                <div class="trust-stat-label">Enterprise Customers</div>
            </div>
            <div class="trust-stat">
                <div class="trust-stat-value">10K+</div>
                <div class="trust-stat-label">Verified Experts</div>
            </div>
            <div class="trust-stat">
                <div class="trust-stat-value">2.3x</div>
                <div class="trust-stat-label">Faster Deal Velocity</div>
            </div>
            <div class="trust-stat">
                <div class="trust-stat-value">98%</div>
                <div class="trust-stat-label">Customer Satisfaction</div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<div class="faq-wrapper">
    <section class="faq-section">
        <div class="faq-header">
            <h2>Frequently Asked <span class="serif-italic">Questions</span></h2>
            <p>Quick answers to common questions about getting in touch.</p>
        </div>

        <div class="faq-list">
            <div class="faq-item">
                <button class="faq-question" type="button" aria-expanded="false">
                    <h4>What's the typical response time?</h4>
                    <div class="faq-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </div>
                </button>
                <div class="faq-answer">
                    <p>Our team typically responds within 2 business hours during standard business hours (9 AM - 6 PM PT). For urgent matters, we also offer 24/7 support for enterprise customers.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question" type="button" aria-expanded="false">
                    <h4>Can I schedule a live demo?</h4>
                    <div class="faq-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </div>
                </button>
                <div class="faq-answer">
                    <p>Absolutely! You can book a personalized demo with our team by selecting "Book a Demo" in the inquiry dropdown above, or by clicking the "Book a Demo" button in our navigation. We'll walk you through exactly how SlashExperts can work for your specific use case.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question" type="button" aria-expanded="false">
                    <h4>I'm interested in becoming an expert. Where do I start?</h4>
                    <div class="faq-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </div>
                </button>
                <div class="faq-answer">
                    <p>Great to hear! Visit our <a href="/become-an-expert/">"Become an Expert"</a> page to learn about the benefits, application process, and how you can start earning by sharing your expertise with prospects evaluating tools you already use and love.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question" type="button" aria-expanded="false">
                    <h4>What security certifications does SlashExperts have?</h4>
                    <div class="faq-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </div>
                </button>
                <div class="faq-answer">
                    <p>We maintain SOC 2 Type II certification and are GDPR compliant. We take data security seriously and can provide detailed security documentation upon request. Visit our <a href="/privacy-hub/">Trust Center</a> for more information.</p>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Globe Section -->
<div class="globe-wrapper-section">
    <section class="globe-section">
        <div class="globe-header">
            <h2>A Truly <span class="serif-italic">Global</span> Presence</h2>
            <p>Connecting experts and prospects across continents, 24 hours a day</p>
        </div>

        <div class="globe-container">
            <div class="globe-wrapper">
                <div class="globe-glow"></div>
                <canvas id="globeCanvas" width="1400" height="1400" style="width: 700px; height: 700px; max-width: 100%; aspect-ratio: 1;"></canvas>
            </div>

            <div class="globe-locations">
                <div class="location-card hq">
                    <div class="location-marker hq">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div class="location-info">
                        <h4>San Francisco</h4>
                        <p>United States</p>
                    </div>
                    <span class="location-badge">HQ</span>
                </div>

                <div class="location-card">
                    <div class="location-marker regular">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div class="location-info">
                        <h4>New York</h4>
                        <p>United States</p>
                    </div>
                </div>

                <div class="location-card">
                    <div class="location-marker regular">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div class="location-info">
                        <h4>London</h4>
                        <p>United Kingdom</p>
                    </div>
                </div>

                <div class="location-card">
                    <div class="location-marker regular">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div class="location-info">
                        <h4>Singapore</h4>
                        <p>Asia Pacific</p>
                    </div>
                </div>

                <div class="location-card">
                    <div class="location-marker regular">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </div>
                    <div class="location-info">
                        <h4>Dubai</h4>
                        <p>Middle East</p>
                    </div>
                </div>

                <div class="more-locations">
                    <div class="more-locations-dots">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                    <span>+ 70 more cities worldwide</span>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}
