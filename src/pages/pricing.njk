{% extends "layouts/base.njk" %}

{% block extraHead %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the free trial work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with a 14-day free trial on any plan—no credit card required. You'll get full access to all features in your chosen plan so you can test SlashExperts with your actual sales process and see real results before committing."
      }
    },
    {
      "@type": "Question",
      "name": "Can I change plans later?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. You can upgrade or downgrade at any time. When upgrading, you'll get immediate access to new features. When downgrading, changes take effect at the start of your next billing cycle."
      }
    },
    {
      "@type": "Question",
      "name": "How long does implementation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most teams are up and running within a week. Day 1 covers account setup, CRM integration, and branding (about 60 minutes). Days 2-3 involve identifying and inviting your initial experts. By day 7, experts have completed their profiles and you're ready to go live."
      }
    },
    {
      "@type": "Question",
      "name": "What CRMs do you integrate with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All plans include native integrations with Salesforce and HubSpot. Growth and Enterprise plans include additional integrations with Outreach, Salesloft, Gong, and more. Enterprise customers also get API access for custom integrations."
      }
    },
    {
      "@type": "Question",
      "name": "How do expert payouts work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SlashExperts handles all expert compensation automatically. You set the reward amount (typically $50-150 per call), and we manage payments directly to your experts. Expert payouts are billed separately from your subscription and you only pay for completed conversations."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a contract or commitment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Monthly plans have no long-term commitment—cancel anytime. Annual plans offer a 20% discount and are paid upfront for the year. Enterprise contracts can be customized to your needs."
      }
    }
  ]
}
</script>
{% endblock %}

