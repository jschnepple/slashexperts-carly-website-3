                        <td><span class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg></span></td>
                    </tr>
                    <tr>
                        <td>Custom analytics &amp; dashboards</td>
                        <td><span class="dash-icon">—</span></td>
