    <!-- FAQ Section -->
    <section class="faq-section">
        <div class="faq-header">
            <div class="section-badge">
                <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                FAQ
            </div>
            <h2>Questions? <span class="serif-italic">Answered.</span></h2>
            <p>Everything you need to know about pricing and getting started.</p>
        </div>

        <div class="faq-list">
            <div class="faq-item active">
                <button class="faq-question">
                    How does the free trial work?
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        Start with a 14-day free trial on any plan—no credit card required. You'll get full access to all features in your chosen plan so you can test SlashExperts with your actual sales process and see real results before committing.
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    Can I change plans later?
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        Absolutely. You can upgrade or downgrade at any time. When upgrading, you'll get immediate access to new features. When downgrading, changes take effect at the start of your next billing cycle.
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    How long does implementation take?
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        Most teams are up and running within a week. Day 1 covers account setup, CRM integration, and branding (about 60 minutes). Days 2-3 involve identifying and inviting your initial experts. By day 7, experts have completed their profiles and you're ready to go live.
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    What CRMs do you integrate with?
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        All plans include native integrations with Salesforce and HubSpot. Growth and Enterprise plans include additional integrations with Outreach, Salesloft, Gong, and more. Enterprise customers also get API access for custom integrations.
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    How do expert payouts work?
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        SlashExperts handles all expert compensation automatically. You set the reward amount (typically $50-150 per call), and we manage payments directly to your experts. Expert payouts are billed separately from your subscription and you only pay for completed conversations.
                    </div>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-question">
                    Is there a contract or commitment?
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
                <div class="faq-answer">
                    <div class="faq-answer-content">
                        Monthly plans have no long-term commitment—cancel anytime. Annual plans offer a 20% discount and are paid upfront for the year. Enterprise contracts can be customized to your needs.
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="cta-content">
            <h2>Ready to accelerate your pipeline?</h2>
            <p>Start your free trial today. No credit card required. See results in your first week.</p>
            <div class="cta-buttons">
                <a href="#" class="btn-cta-primary">
                    Start Free Trial
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="#" class="btn-cta-secondary">
                    Talk to Sales
                </a>
            </div>
        </div>
    </section>
{% endblock %}
