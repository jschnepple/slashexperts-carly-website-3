---
title: Pricing - SlashExperts
description: Start small and prove ROI, then scale without limits. No hidden fees, no surprises—just results.
lightNav: true
pageCSS: pricing
pageJS: pricing
---

{% extends "layouts/base.njk" %}

{% block content %}
<!-- Hero + Pricing Background Wrapper -->
<div class="hero-pricing-wrapper">
        <!-- Background Effects -->
        <div class="background-gradient-wrapper">
            <div class="background-gradient"></div>
            <div class="background-gradient-secondary"></div>
            <div class="background-gradient-tertiary"></div>
            <div class="background-lines"></div>
        </div>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
            <div class="section-badge">
                <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                </svg>
                Simple Pricing
            </div>
            <h1>
                Invest in <span class="serif-italic">authentic</span><br>
                <span class="gradient-text">customer connections</span>
            </h1>
            <p class="hero-subtitle">
                Start small and prove ROI, then scale without limits. No hidden fees, no surprises—just results.
            </p>
            <div class="billing-toggle">
                <button class="billing-option active" data-billing="monthly">Monthly</button>
                <button class="billing-option" data-billing="annual">Annual<span class="save-badge">Save 20%</span></button>
            </div>
        </div>
    </section>

    <!-- Pricing Cards -->
    <section class="pricing-section">
        <div class="pricing-grid">
            <!-- Essentials Plan -->
            <div class="pricing-card">
                <div class="plan-icon essentials">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <div class="plan-name">Essentials</div>
                <p class="plan-tagline">Perfect for testing expert-led growth. Start with your top references and prove ROI.</p>
                <div class="plan-price">
                    <span class="price-value" data-monthly="$2K" data-annual="$1.6K">$2K</span>
                    <span class="price-period">/month</span>
                </div>
                <p class="price-note" data-monthly="Billed monthly" data-annual="Billed annually ($19.2K/year)">Billed monthly</p>
                <p class="annual-savings" data-plan="essentials">You save $4,800/year</p>
                <ul class="plan-features">
                    <li>
                        <span class="feature-check cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Up to 5 expert references
                    </li>
                    <li>
                        <span class="feature-check cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        3 active deals at a time
                    </li>
                    <li>
                        <span class="feature-check cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Basic analytics dashboard
                    </li>
                    <li>
                        <span class="feature-check cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        CRM integration (Salesforce, HubSpot)
                    </li>
                    <li>
                        <span class="feature-check cyan">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Email support
                    </li>
                </ul>
                <a href="#" class="btn-plan secondary">Start Free Trial</a>
            </div>

            <!-- Growth Plan -->
            <div class="pricing-card featured">
                <div class="popular-badge">Most Popular</div>
                <div class="plan-icon growth">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                        <polyline points="17 6 23 6 23 12"/>
                    </svg>
                </div>
                <div class="plan-name">Growth</div>
                <p class="plan-tagline">Built for revenue teams ready to scale. Unlimited experts and automations.</p>
                <div class="plan-price">
                    <span class="price-value" data-monthly="$3K" data-annual="$2.4K">$3K</span>
                    <span class="price-period">/month</span>
                </div>
                <p class="price-note" data-monthly="Billed monthly" data-annual="Billed annually ($28.8K/year)">Billed monthly</p>
                <p class="annual-savings" data-plan="growth">You save $7,200/year</p>
                <ul class="plan-features">
                    <li>
                        <span class="feature-check violet">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        <strong>Unlimited</strong> experts
                    </li>
                    <li>
                        <span class="feature-check violet">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        <strong>Unlimited</strong> deals &amp; automations
                    </li>
                    <li>
                        <span class="feature-check violet">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Advanced analytics &amp; ROI tracking
                    </li>
                    <li>
                        <span class="feature-check violet">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        All integrations included
                    </li>
                    <li>
                        <span class="feature-check violet">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Custom workflows &amp; triggers
                    </li>
                    <li>
                        <span class="feature-check violet">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Priority support
                    </li>
                </ul>
                <a href="#" class="btn-plan primary">Start Free Trial</a>
            </div>

            <!-- Enterprise Plan -->
            <div class="pricing-card">
                <div class="plan-icon enterprise">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                    </svg>
                </div>
                <div class="plan-name">Enterprise</div>
                <p class="plan-tagline">Complete solution with advanced analytics and dedicated support for complex sales motions.</p>
                <div class="plan-price">
                    <span class="price-value" data-monthly="$5K" data-annual="$4K">$5K</span>
                    <span class="price-period">/month</span>
                </div>
                <p class="price-note" data-monthly="Billed monthly" data-annual="Billed annually ($48K/year)">Billed monthly</p>
                <p class="annual-savings" data-plan="enterprise">You save $12,000/year</p>
                <ul class="plan-features">
                    <li>
                        <span class="feature-check orange">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Everything in Growth
                    </li>
                    <li>
                        <span class="feature-check orange">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Dedicated Customer Success Manager
                    </li>
                    <li>
                        <span class="feature-check orange">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        Custom analytics &amp; reporting
                    </li>
                    <li>
                        <span class="feature-check orange">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        SLA guarantee &amp; API access
                    </li>
                    <li>
                        <span class="feature-check orange">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        White-label options available
                    </li>
                    <li>
                        <span class="feature-check orange">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </span>
                        SSO &amp; advanced security
                    </li>
                </ul>
                <a href="#" class="btn-plan outline">Contact Sales</a>
            </div>
        </div>

        <!-- Feature Comparison Table - moved here -->
        <div class="comparison-header" style="margin-top: 80px;">
            <div class="section-badge">
                <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                </svg>
                Compare Plans
            </div>
            <h2>Full Feature Comparison</h2>
            <p>See everything included in each plan to find your perfect fit.</p>
        </div>

        <div class="comparison-table-wrapper">
            <table class="comparison-table">
                <thead>
                    <tr>
                        <th>Features</th>
                        <th class="plan-header">Essentials<span class="th-price">$2K/mo</span></th>
                        <th class="plan-header featured">Growth<span class="th-price">$3K/mo</span></th>
                        <th class="plan-header">Enterprise<span class="th-price">$5K/mo</span></th>
                    </tr>
                </thead>
                <tbody>
