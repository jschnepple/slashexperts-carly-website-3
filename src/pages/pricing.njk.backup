    </div><!-- End hero-pricing-wrapper -->

    <!-- Social Proof Bar -->
    <section class="social-proof">
        <div class="social-proof-content">
            <p>Trusted by revenue teams at leading companies</p>
            <div class="logos-carousel-wrapper">
                <div class="logos-carousel">
                    <div class="logo-item">Sendspark</div>
                    <div class="logo-item">Sendoso</div>
                    <div class="logo-item">Overdryve</div>
                    <div class="logo-item">Mobly</div>
                    <div class="logo-item">OutboundSync</div>
                    <div class="logo-item">Warmly</div>
                    <div class="logo-item">Spara</div>
                    <div class="logo-item">Udemy</div>
                    <!-- Duplicate for seamless loop -->
